# target to generate assembly for a file
src/t_pub_msg.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/t_pub_msg.dir/build.make CMakeFiles/t_pub_msg.dir/src/t_pub_msg.cpp.s
.PHONY : src/t_pub_msg.cpp.s

